/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
  background-color: #f5f5f5;
}

.container {
  padding: 30rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
}

.btn-primary:active {
  background-color: #096dd9;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #666666;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  border: 1px solid #d9d9d9;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.text-primary {
  color: #1890ff;
}

.text-secondary {
  color: #999999;
  font-size: 24rpx;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}
