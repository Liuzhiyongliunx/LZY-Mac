/* pages/records/records.wxss */

.page {
  min-height: 100vh;
  background: #f4f6f9;
  padding-bottom: 40rpx;
}

/* ---- 月份导航 ---- */
.month-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx 40rpx;
}
.nav-arrow {
  font-size: 52rpx;
  color: #1890ff;
  padding: 0 20rpx;
}
.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

/* ---- 统计卡片 ---- */
.stats-card {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stats-row {
  display: flex;
  align-items: center;
}
.stat-col {
  flex: 1;
  text-align: center;
}
.stat-val {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
}
.stat-val.blue { color: #1890ff; }
.stat-lbl {
  font-size: 22rpx;
  color: #aaa;
}
.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* ---- 柱状图 ---- */
.chart-card {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 160rpx;
  gap: 10rpx;
}
.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}
.bar-val {
  font-size: 20rpx;
  color: #1890ff;
  height: 28rpx;
  line-height: 28rpx;
}
.bar-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  background: #f5f5f5;
  border-radius: 6rpx 6rpx 0 0;
  overflow: hidden;
}
.bar-fill {
  width: 100%;
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  transition: height 0.4s;
}
.bar-has   { background: #91d5ff; }
.bar-today { background: #1890ff; }
.bar-empty { background: transparent; }
.bar-label {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}
.today-label { color: #1890ff; font-weight: 600; }

/* ---- 视图切换 ---- */
.view-tabs {
  display: flex;
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.view-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}
.view-tab.active {
  background: #1890ff;
  color: #fff;
  font-weight: 600;
}

/* ---- 列表视图 ---- */
.record-list {
  padding: 20rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.record-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.record-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
  margin-right: 24rpx;
}
.rec-day {
  font-size: 44rpx;
  font-weight: 700;
  color: #222;
  line-height: 1;
}
.rec-week {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}
.record-right {
  flex: 1;
}
.rec-row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.rec-time {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.rec-badge {
  background: #e6f7ff;
  color: #1890ff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.rec-progress-bar {
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.rec-progress-fill {
  height: 100%;
  background: #52c41a;
  border-radius: 4rpx;
}
.rec-done-txt {
  font-size: 22rpx;
  color: #aaa;
}
.rec-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 12rpx;
}

/* ---- 日历视图 ---- */
.calendar-box {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.cal-header {
  display: flex;
  margin-bottom: 12rpx;
}
.cal-week-label {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
}
.cal-grid {
  display: flex;
  flex-wrap: wrap;
}
.cal-cell {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin: 4rpx 0;
}
.cal-cell.empty { background: transparent; }
.cal-cell.weekend .cal-day-num { color: #bbb; }
.cal-cell.today { background: #e6f7ff; }
.cal-cell.today .cal-day-num { color: #1890ff; font-weight: 700; }
.cal-cell.checked { background: #1890ff; }
.cal-cell.checked .cal-day-num { color: #fff; font-weight: 600; }
.cal-cell.missed .cal-day-num { color: #ff9999; }
.cal-day-num { font-size: 28rpx; color: #333; }
.cal-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.8);
  margin-top: 2rpx;
}

/* 图例 */
.cal-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #888;
}
.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.dot-checked { background: #1890ff; }
.dot-missed  { background: #ffaaaa; }
.dot-weekend { background: #ddd; }

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }
