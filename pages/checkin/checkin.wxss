/* pages/checkin/checkin.wxss */

.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 打卡头部 */
.checkin-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-date {
  font-size: 36rpx;
  font-weight: 600;
}

.header-weekday {
  font-size: 28rpx;
  opacity: 0.8;
  margin-left: 20rpx;
}

.time-text {
  font-size: 48rpx;
  font-weight: 300;
}

/* 工作内容区域 */
.work-section {
  margin: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-count {
  font-size: 26rpx;
  color: #999;
}

/* 添加任务按钮 */
.add-task {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  color: #1890ff;
  margin-bottom: 24rpx;
}

.add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

/* 任务列表 */
.task-list {
  margin-top: 20rpx;
}

.task-item {
  background-color: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.task-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.task-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.task-time {
  font-size: 26rpx;
  color: #1890ff;
}

.task-actions {
  display: flex;
  gap: 20rpx;
}

.action-edit, .action-delete {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.action-edit {
  color: #1890ff;
}

.action-delete {
  color: #ff4d4f;
}

.task-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.6;
}

/* 空状态提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 统计区域 */
.stats-section {
  margin: 0 30rpx 30rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #999;
}

.stats-divider {
  width: 1rpx;
  height: 80rpx;
  background-color: #e8e8e8;
}

/* 打卡按钮区域 */
.checkin-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.checkin-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

.checkin-btn.disabled {
  background-color: #ccc;
}

.checkin-tips {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 20rpx;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer button {
  flex: 1;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 时间选择器 */
.time-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-btn {
  padding: 16rpx 28rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fafafa;
}

.time-btn.active {
  background-color: #1890ff;
  border-color: #1890ff;
  color: #fff;
}

/* 优先级选择器 */
.priority-picker {
  display: flex;
  gap: 16rpx;
}

.priority-btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fafafa;
}

.priority-btn.active {
  color: #fff;
}

.priority-btn.active.high {
  background-color: #ff4d4f;
  border-color: #ff4d4f;
}

.priority-btn.active.medium {
  background-color: #faad14;
  border-color: #faad14;
}

.priority-btn.active.low {
  background-color: #52c41a;
  border-color: #52c41a;
}

/* 优先级小圆点 */
.task-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.priority-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.priority-dot.priority-high   { background: #ff4d4f; }
.priority-dot.priority-medium { background: #1890ff; }
.priority-dot.priority-low    { background: #52c41a; }

/* 任务元信息行 */
.task-meta-row {
  display: flex;
  gap: 20rpx;
}
.task-deadline {
  font-size: 24rpx;
  color: #fa8c16;
}

/* 截止日期选择器 */
.date-picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #bbb;
  background: #fafafa;
}
.date-picker-box.has-value {
  color: #333;
  background: #fff;
  border-color: #1890ff;
}
.picker-arrow {
  font-size: 32rpx;
  color: #999;
}
.clear-date {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 10rpx;
  display: block;
}
