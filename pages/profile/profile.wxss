/* pages/profile/profile.wxss */

.page {
  min-height: 100vh;
  background: #f4f6f9;
  padding-bottom: 60rpx;
}

/* ---- 顶部头像区 ---- */
.profile-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 50rpx;
}
.avatar-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 20rpx;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.avatar-edit-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.4);
  border-radius: 0 0 70rpx 70rpx;
  text-align: center;
  padding: 6rpx 0;
}
.avatar-edit-txt {
  font-size: 20rpx;
  color: #fff;
}
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}
.user-dept {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* ---- 月度进度条 ---- */
.progress-card {
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.progress-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.progress-rate {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 600;
}
.progress-bar-bg {
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #69c0ff);
  border-radius: 8rpx;
  transition: width 0.5s;
}
.progress-pct {
  font-size: 24rpx;
  color: #aaa;
}

/* ---- 四格统计 ---- */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stats-cell {
  width: 50%;
  padding: 32rpx 0;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}
.stats-cell:nth-child(2n) { border-right: none; }
.stats-cell:nth-child(3),
.stats-cell:nth-child(4) { border-bottom: none; }
.stats-val {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}
.stats-val.blue   { color: #1890ff; }
.stats-val.green  { color: #52c41a; }
.stats-val.orange { color: #fa8c16; }
.stats-lbl {
  font-size: 22rpx;
  color: #aaa;
}

/* ---- 菜单组 ---- */
.menu-group {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}
.menu-icon-txt {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}
.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-tag {
  font-size: 20rpx;
  color: #aaa;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}
.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}
.menu-divider {
  height: 1rpx;
  background: #f5f5f5;
}

/* ---- 退出 ---- */
.logout-row {
  padding: 40rpx 24rpx 0;
}
.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  border: 2rpx solid #ffccc7;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #ff4d4f;
  text-align: center;
}
.logout-btn::after { border: none; }

.version-txt {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 32rpx 0 0;
}

/* ---- 诊断按钮 ---- */
.diag-row {
  text-align: center;
  padding: 16rpx 0 30rpx;
}
.diag-txt {
  font-size: 24rpx;
  color: #999;
}

/* ---- 编辑弹窗 ---- */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.modal.show {
  opacity: 1;
  pointer-events: auto;
}
.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.modal-panel {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}
.modal-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.modal-title { font-size: 32rpx; font-weight: 600; }
.modal-close { font-size: 48rpx; color: #aaa; padding: 0 10rpx; }
.modal-bd { padding: 32rpx; }
.edit-item { margin-bottom: 28rpx; }
.edit-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.edit-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.modal-ft {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx 48rpx;
}
.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
}
.btn-cancel::after { border: none; }
.btn-save {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #1890ff;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #fff;
}
.btn-save::after { border: none; }
